#!/usr/bin/env bash
# vpn — unified VPN control for Tailscale, AWS VPN, GlobalProtect
# Usage: vpn <command> [args]

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$0" 2>/dev/null || realpath "$0")")" && pwd)"
source "$SCRIPT_DIR/lib.sh"

usage() {
    cat <<EOF
Usage: vpn <command>

Status:
  status          Show status of all VPNs
  check           Full network diagnostics
  routes          Show VPN-related routes

Individual VPN control:
  ts-up           Connect Tailscale
  ts-down         Disconnect Tailscale
  aws-up          Connect AWS VPN (cycles Tailscale if needed)
  aws-down        Disconnect AWS VPN
EOF
    if [[ "$GP_ENABLED" == "true" ]]; then
        cat <<EOF
  gp-up           Connect GlobalProtect
  gp-down         Disconnect GlobalProtect
EOF
    fi
    cat <<EOF

Presets (safe combinations):
  preset aws-ts   AWS + Tailscale
EOF
    if [[ "$GP_ENABLED" == "true" ]]; then
        echo "  preset all      All three (AWS + GlobalProtect + Tailscale)"
    fi
    cat <<EOF

Recovery:
  kill-all        Disconnect all VPNs
  recover         Kill all + reconnect default gateway

Setup:
  setup           Configure passwordless sudo for VPN tools
EOF
    if [[ "$GP_ENABLED" == "true" ]]; then
        echo "  gp-set-credentials  Store GlobalProtect credentials in keychain"
    fi
}

cmd_status() {
    echo "─── VPN Status ───────────────────────────"
    printf "  %-14s %s\n" "Tailscale:" "$(ts_status)"
    printf "  %-14s %s\n" "AWS VPN:" "$(aws_vpn_status)"
    [[ "$GP_ENABLED" == "true" ]] && printf "  %-14s %s\n" "GlobalProtect:" "$(gp_status)"
    echo "───────────────────────────────────────────"
}

cmd_kill_all() {
    warn "Disconnecting all VPNs..."
    rm -f "$AWS_VPN_RECONNECT_FLAG"
    rm -f "$GP_RECONNECT_FLAG"
    local failed=0
    ts_down  || failed=1
    aws_vpn_down || failed=1
    [[ "$GP_ENABLED" == "true" ]] && { gp_down || failed=1; }
    if [ $failed -eq 0 ]; then
        ok "All VPNs disconnected"
    else
        err "Some VPNs failed to disconnect"
    fi
    return $failed
}

cmd_recover() {
    warn "Recovery: killing all VPNs and restoring network..."
    cmd_kill_all || true
    sleep 2

    # Flush route cache
    log "Flushing route cache..."
    route -n flush 2>/dev/null || true

    # Check if default gateway is back
    local gw
    gw=$(netstat -rn -f inet 2>/dev/null | awk '/^default/{print $2; exit}')
    if [ -n "$gw" ]; then
        ok "Default gateway: $gw"
    else
        err "No default gateway found — may need manual intervention"
        return 1
    fi

    net_check
}

cmd_preset() {
    local preset="${1:-}"
    case "$preset" in
        aws-ts)
            log "Preset: AWS + Tailscale (critical combo)"

            # Force clean ordering: disconnect all, then reconnect in safe order.
            # Safety watchdog ensures Tailscale is restored within 3 minutes
            # even if the AWS Entra SAML flow hangs.
            ts_down  || true
            ts_watchdog_start
            [[ "$GP_ENABLED" == "true" ]] && { gp_down || true; }
            aws_vpn_down || true
            sleep 1

            # Order matters: AWS first, then Tailscale
            # AWS VPN tends to set aggressive default routes;
            # Tailscale added after can coexist via its CGNAT range (100.x)
            log "Phase 1: AWS VPN..."
            aws_vpn_up || { ts_watchdog_stop; ts_up || true; err "AWS VPN failed — aborting preset"; return 1; }

            log "Saving route state pre-Tailscale..."
            route_snapshot

            ts_watchdog_stop
            log "Phase 2: Tailscale..."
            ts_up || { err "Tailscale failed — AWS VPN still up"; return 1; }

            log "Post-connect route state:"
            route_snapshot

            # Verify both are still up
            sleep 2
            local ts_ok aws_ok
            ts_ok=$(ts_status)
            aws_ok=$(aws_vpn_status)
            if [ "$ts_ok" = "connected" ] && [ "$aws_ok" = "connected" ]; then
                ok "Preset aws-ts: both VPNs connected!"
            else
                err "Preset aws-ts: state mismatch — Tailscale=$ts_ok, AWS=$aws_ok"
                warn "Route table for debugging:"
                route_snapshot
                return 1
            fi

            net_check
            ;;
        all)
            if [[ "$GP_ENABLED" == "true" ]]; then
                log "Preset: All three (AWS + GlobalProtect + Tailscale)"
            else
                log "Preset: AWS + Tailscale"
            fi

            log "Ensuring clean state..."
            ts_down  || true
            ts_watchdog_start
            [[ "$GP_ENABLED" == "true" ]] && { gp_down || true; }
            aws_vpn_down || true
            sleep 1

            log "Phase 1: AWS VPN..."
            aws_vpn_up || { ts_watchdog_stop; ts_up || true; err "AWS VPN failed — aborting preset"; return 1; }

            if [[ "$GP_ENABLED" == "true" ]]; then
                log "Phase 2: GlobalProtect..."
                gp_up || { err "GlobalProtect failed — AWS VPN still up"; return 1; }
            fi

            log "Saving route state pre-Tailscale..."
            route_snapshot

            ts_watchdog_stop
            log "Phase $( [[ "$GP_ENABLED" == "true" ]] && echo 3 || echo 2 ): Tailscale..."
            ts_up || { err "Tailscale failed"; return 1; }

            log "Post-connect route state:"
            route_snapshot

            sleep 2
            local ts_ok aws_ok
            ts_ok=$(ts_status)
            aws_ok=$(aws_vpn_status)
            if [[ "$GP_ENABLED" == "true" ]]; then
                local gp_ok
                gp_ok=$(gp_status)
                if [ "$ts_ok" = "connected" ] && [ "$aws_ok" = "connected" ] && [ "$gp_ok" = "connected" ]; then
                    ok "Preset all: all three VPNs connected!"
                else
                    err "Preset all: state mismatch — Tailscale=$ts_ok, AWS=$aws_ok, GlobalProtect=$gp_ok"
                    warn "Route table for debugging:"
                    route_snapshot
                    return 1
                fi
            else
                if [ "$ts_ok" = "connected" ] && [ "$aws_ok" = "connected" ]; then
                    ok "Preset all: both VPNs connected!"
                else
                    err "Preset all: state mismatch — Tailscale=$ts_ok, AWS=$aws_ok"
                    warn "Route table for debugging:"
                    route_snapshot
                    return 1
                fi
            fi

            net_check
            ;;
        *)
            err "Unknown preset: $preset"
            echo "Available presets: aws-ts, all"
            return 1
            ;;
    esac
}

# ── Main dispatch ───────────────────────────────────────────────────
gp_guard() {
    if [[ "$GP_ENABLED" != "true" ]]; then
        err "GlobalProtect is disabled (see vpn/config)"
        exit 1
    fi
}

case "${1:-}" in
    status)     cmd_status ;;
    check)      net_check ;;
    routes)     route_snapshot ;;
    ts-up)      ts_up ;;
    ts-down)    ts_down ;;
    aws-up)     aws_vpn_up ;;
    aws-down)   aws_vpn_down ;;
    gp-up)      gp_guard; gp_up ;;
    gp-down)    gp_guard; gp_down ;;
    preset)     cmd_preset "${2:-}" ;;
    kill-all)   cmd_kill_all ;;
    recover)    cmd_recover ;;
    gp-set-credentials)
        gp_guard
        echo -n "GlobalProtect username (lastname_firstname): "
        read -r gp_user
        echo -n "GlobalProtect password (céges jelszó): "
        read -rs gp_pw
        echo
        gp_store_credentials "$gp_user" "$gp_pw"
        ;;
    setup|setup-sudoers)
        ovpn_bin="/Applications/AWS VPN Client/AWS VPN Client.app/Contents/Resources/openvpn/acvc-openvpn"
        openconnect_bin="$(command -v openconnect 2>/dev/null || echo /opt/homebrew/bin/openconnect)"
        sudoers_file="/etc/sudoers.d/vpn"
        if [ ! -x "$ovpn_bin" ]; then
            err "AWS VPN Client not installed — install it first"
            err "  https://self-service.clientvpn.amazonaws.com/endpoints/cvpn-endpoint-022755a701a9c6b8c"
            exit 1
        fi
        if [ ! -x "$openconnect_bin" ]; then
            err "openconnect not installed — run: brew install openconnect"
            exit 1
        fi
        # Migrate old sudoers file if present
        [ -f /etc/sudoers.d/vpn-aws ] && sudo rm -f /etc/sudoers.d/vpn-aws
        ovpn_bin_escaped="${ovpn_bin// /\\ }"
        # Build expected sudoers content
        expected_sudoers=$(printf '%s ALL=(ALL) NOPASSWD: %s *\n' \
            "$USER" "$ovpn_bin_escaped" \
            "$USER" "$openconnect_bin" \
            "$USER" "/bin/kill" \
            "$USER" "/usr/bin/tee" \
            "$USER" "/bin/mkdir" \
            "$USER" "/bin/rm" \
            "$USER" "/usr/bin/sed" \
            "$USER" "/usr/sbin/dscacheutil" \
            "$USER" "/usr/bin/killall")
        if [ -f "$sudoers_file" ]; then
            current=$(sudo cat "$sudoers_file" 2>/dev/null)
            if [ "$current" = "$expected_sudoers" ]; then
                ok "Passwordless sudo already configured — nothing to do"
                exit 0
            fi
            warn "Sudoers file exists but is outdated — updating"
        fi
        echo "This will allow passwordless sudo for VPN tools."
        echo ""
        echo "  File: $sudoers_file"
        echo "  Rules:"
        echo "    $USER ALL=(ALL) NOPASSWD: $ovpn_bin_escaped *"
        echo "    $USER ALL=(ALL) NOPASSWD: $openconnect_bin *"
        echo "    $USER ALL=(ALL) NOPASSWD: /bin/kill *"
        echo "    $USER ALL=(ALL) NOPASSWD: /usr/bin/tee *"
        echo "    $USER ALL=(ALL) NOPASSWD: /bin/mkdir *"
        echo "    $USER ALL=(ALL) NOPASSWD: /bin/rm *"
        echo "    $USER ALL=(ALL) NOPASSWD: /usr/bin/sed *"
        echo "    $USER ALL=(ALL) NOPASSWD: /usr/sbin/dscacheutil *"
        echo "    $USER ALL=(ALL) NOPASSWD: /usr/bin/killall *"
        echo ""
        echo -n "Continue? [y/N] "
        read -r confirm
        if [ "$confirm" = "y" ] || [ "$confirm" = "Y" ]; then
            echo "$expected_sudoers" | sudo tee "$sudoers_file" > /dev/null
            sudo chmod 440 "$sudoers_file"
            sudo visudo -cf "$sudoers_file" && ok "Done — VPN tools now work without password prompts" \
                || { err "sudoers syntax error — removing broken file"; sudo rm -f "$sudoers_file"; }
        fi
        ;;
    -h|--help|help|"") usage ;;
    *)
        err "Unknown command: $1"
        usage
        exit 1
        ;;
esac
